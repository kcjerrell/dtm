{
  "name": "dtm",
  "author": "kcjerrell",
  "private": true,
  "version": "0.5.3",
  "type": "module",
  "scripts": {
    "dev": "TAURI_WEBDRIVER_PORT=4445 tauri dev --features webdriver",
    "dev:web": "MOCK_TAURI=true vite",
    "dev:vite": "vite",
    "build": "vite build",
    "build:mac": "dotenv -- tauri build",
    "build:universal": "dotenv -- tauri build --target universal-apple-darwin",
    "build:debug": "dotenv -- tauri build --debug --features webdriver",
    "clean:vite": "rm --recursive node_modules/.vite & rm --recursive  node_modules/.vite-temp",
    "preview": "vite preview",
    "tauri": "dotenv -- tauri",
    "gen-icons": "tauri icon ./app-icon.png",
    "generate:entities": "dotenv -e .env -- sh -c 'sea-orm-cli generate entity --database-url \"$DB_URL\" --ignore-tables images_fts,images_fts_data,images_fts_docsize,images_fts_idx,images_fts_config,images_fts_content --output-dir src-tauri/entity/src --with-serde serialize --entity-format dense'",
    "update-fbs": "./scripts/update-fbs.sh",
    "version": "tsx ./scripts/version.ts",
    "wdio": "DTM_USE_DEV=false wdio run ./test/wdio.conf.ts",
    "wdio:dev": "DTM_USE_DEV=true wdio run ./test/wdio.conf.ts"
  },
  "dependencies": {
    "@chakra-ui/react": "^3.35.0",
    "@emotion/react": "^11.14.0",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-clipboard-manager": "~2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-http": "^2.5.9",
    "@tauri-apps/plugin-log": "^2.8.0",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-process": "~2",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-store": "^2.4.3",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@tauri-apps/plugin-window-state": "~2",
    "@tauri-store/valtio": "^3.3.0",
    "@uiw/react-json-view": "^2.0.0-alpha.42",
    "ahooks": "^3.9.7",
    "async-mutex": "^0.5.0",
    "derive-valtio": "^0.2.0",
    "eventemitter3": "^5.0.4",
    "exifr": "github:m-hayabusa/exifr#2cf6c14fcd8eab52a7a7de53af7fdb01a4a9f90f",
    "exifreader": "^4.38.1",
    "motion": "^12.38.0",
    "nanoid": "^5.1.11",
    "next-themes": "^0.4.6",
    "plist": "^3.1.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.6",
    "react-error-boundary": "^6.1.1",
    "react-hotkeys-hook": "^5.3.2",
    "react-icons": "^5.6.0",
    "tauri-plugin-clipboard-api": "^2.1.11",
    "tauri-plugin-fs-watch-api": "https://github.com/tauri-apps/tauri-plugin-fs-watch#v1",
    "tauri-plugin-nspopover": "git+https://github.com/freethinkel/tauri-nspopover-plugin",
    "valtio": "^2.3.2",
    "valtio-reactive": "^0.2.0"
  },
  "devDependencies": {
    "@babel/plugin-proposal-decorators": "^7.29.0",
    "@biomejs/biome": "2.3.11",
    "@chakra-ui/cli": "^3.35.0",
    "@octokit/rest": "^22.0.1",
    "@tauri-apps/cli": "^2.11.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/fs-extra": "^11.0.4",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.6.0",
    "@types/plist": "^3.0.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@wdio/cli": "^9.27.1",
    "@wdio/concise-reporter": "^9.27.1",
    "@wdio/globals": "^9.27.1",
    "@wdio/json-reporter": "^9.20.0",
    "@wdio/local-runner": "^9.27.1",
    "@wdio/mocha-framework": "^9.23.2",
    "@wdio/spec-reporter": "^9.27.1",
    "@wdio/types": "^9.27.1",
    "@wdio/visual-service": "^9.2.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "expect-webdriverio": "^5.6.5",
    "fs-extra": "^11.3.5",
    "globals": "^17.6.0",
    "jiti": "^2.7.0",
    "jsdom": "^27.4.0",
    "react-redux": "^9.2.0",
    "rollup-plugin-visualizer": "^6.0.11",
    "tscanner": "^0.1.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.10",
    "vite-bundle-visualizer": "^1.2.1",
    "vite-plugin-html-injection": "^1.5.2",
    "vite-plugin-wasm": "^3.6.0",
    "vitest": "^4.1.5"
  }
}
